{
  "gateway": {
    "name": "Synnaut Fleet"
  },
  "agents": {
    "defaults": {
      "subagents": {
        "maxConcurrent": 8,
        "runTimeoutSeconds": 900,
        "archiveAfterMinutes": 120
      }
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "王熙凤",
        "workspace": "./workspace-main",
        "subagents": {
          "allowAgents": [
            "pilot-general",
            "pilot-research",
            "pilot-build"
          ]
        },
        "tools": {
          "allow": [
            "sessions_spawn",
            "sessions_list",
            "sessions_send",
            "read",
            "write",
            "web_search",
            "exec"
          ]
        }
      },
      {
        "id": "pilot-general",
        "name": "贾宝玉",
        "workspace": "./workspace-pilot-general",
        "subagents": {
          "allowAgents": [
            "worker-drive",
            "worker-guard",
            "worker-sense"
          ]
        },
        "tools": {
          "allow": [
            "sessions_spawn",
            "read",
            "write",
            "web_search",
            "exec"
          ]
        }
      },
      {
