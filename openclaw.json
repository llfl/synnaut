{
  "gateway": {
    "name": "Synnaut Fleet"
  },
  "agents": {
    "defaults": {
      "subagents": {
        "maxConcurrent": 8,
        "runTimeoutSeconds": 900,
        "archiveAfterMinutes": 120
      }
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "Chief Mate",
        "workspace": "./workspace-main",
        "subagents": {
          "allowAgents": ["pilot-general", "pilot-research", "pilot-build"]
        },
        "tools": {
          "allow": [
            "sessions_spawn",
            "sessions_list",
            "sessions_send",
            "read",
            "write",
            "web_search",
            "exec"
          ]
        }
      },
      {
        "id": "pilot-general",
        "name": "Pilot General",
        "workspace": "./workspace-pilot-general",
        "subagents": {
          "allowAgents": ["worker-drive", "worker-guard", "worker-sense"]
        },
        "tools": {
          "allow": [
            "sessions_spawn",
            "read",
            "write",
            "web_search",
            "exec"
          ]
        }
      },
      {
        "id": "pilot-research",
        "name": "Pilot Research",
        "workspace": "./workspace-pilot-research",
        "subagents": {
          "allowAgents": ["worker-drive", "worker-guard", "worker-sense"]
        },
        "tools": {
          "allow": [
            "sessions_spawn",
            "read",
            "write",
            "web_search",
            "web_fetch"
          ]
        }
      },
      {
        "id": "pilot-build",
        "name": "Pilot Build",
        "workspace": "./workspace-pilot-build",
        "subagents": {
          "allowAgents": ["worker-drive", "worker-guard", "worker-sense"]
        },
        "tools": {
          "allow": [
            "sessions_spawn",
            "read",
            "write",
            "exec"
          ]
        }
      },
      {
        "id": "worker-drive",
        "name": "Worker Drive",
        "workspace": "./workspace-worker-drive",
        "subagents": {
          "allowAgents": []
        },
        "tools": {
          "allow": [
            "read",
            "write",
            "exec"
          ]
        }
      },
      {
        "id": "worker-guard",
        "name": "Worker Guard",
        "workspace": "./workspace-worker-guard",
        "subagents": {
          "allowAgents": []
        },
        "tools": {
          "allow": [
            "read",
            "exec"
          ]
        }
      },
      {
        "id": "worker-sense",
        "name": "Worker Sense",
        "workspace": "./workspace-worker-sense",
        "subagents": {
          "allowAgents": []
        },
        "tools": {
          "allow": [
            "read",
            "write",
            "web_search",
            "web_fetch"
          ]
        }
      }
    ]
  }
}
